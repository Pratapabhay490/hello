# TeraBooks Player - Environment Variables Example
# Copy this file to .env.local and update with your values

# ============================================
# APPLICATION SETTINGS
# ============================================

# Public URL of your application
NEXT_PUBLIC_APP_URL=http://localhost:3000

# API Base URL (usually same as app URL in production)
NEXT_PUBLIC_API_URL=http://localhost:3000/api

# ============================================
# SECURITY
# ============================================

# JWT Secret Key - CHANGE THIS IN PRODUCTION!
# Generate a secure random string: openssl rand -base64 32
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production-use-strong-random-string

# JWT Token Expiration (e.g., "7d", "24h", "30m")
JWT_EXPIRES_IN=7d

# Password Hashing Rounds (bcrypt)
BCRYPT_ROUNDS=10

# ============================================
# DATABASE (Optional - for future implementation)
# ============================================

# Uncomment and configure when you add a real database

# DATABASE_URL=postgresql://user:password@localhost:5432/terabooks
# DATABASE_POOL_SIZE=20

# ============================================
# STORAGE (Optional - for video/image uploads)
# ============================================

# AWS S3 Configuration
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key
# AWS_REGION=us-east-1
# AWS_S3_BUCKET=terabooks-videos

# Cloudinary Configuration
# CLOUDINARY_CLOUD_NAME=your-cloud-name
# CLOUDINARY_API_KEY=your-api-key
# CLOUDINARY_API_SECRET=your-api-secret

# ============================================
# EXTERNAL SERVICES (Optional)
# ============================================

# Email Service (e.g., SendGrid, AWS SES)
# EMAIL_SERVICE_API_KEY=your-email-api-key
# EMAIL_FROM=noreply@terabooks.com

# Analytics (e.g., Google Analytics)
# NEXT_PUBLIC_GA_TRACKING_ID=G-XXXXXXXXXX

# Sentry Error Tracking
# SENTRY_DSN=your-sentry-dsn
# NEXT_PUBLIC_SENTRY_DSN=your-public-sentry-dsn

# ============================================
# RATE LIMITING
# ============================================

# Max requests per time window
RATE_LIMIT_MAX_REQUESTS=100

# Time window in milliseconds
RATE_LIMIT_WINDOW=60000

# ============================================
# REDIS (Optional - for production rate limiting)
# ============================================

# REDIS_URL=redis://localhost:6379
# REDIS_PASSWORD=your-redis-password

# ============================================
# VIDEO PROCESSING (Optional)
# ============================================

# FFmpeg Configuration
# FFMPEG_PATH=/usr/bin/ffmpeg
# VIDEO_QUALITY_PRESETS=360p,720p,1080p

# ============================================
# FEATURE FLAGS
# ============================================

# Enable/disable features
NEXT_PUBLIC_ENABLE_COMMENTS=false
NEXT_PUBLIC_ENABLE_RATINGS=false
NEXT_PUBLIC_ENABLE_SOCIAL_SHARE=true
NEXT_PUBLIC_ENABLE_LIVE_STREAMING=false

# ============================================
# DEVELOPMENT
# ============================================

# Node Environment (development, production, test)
NODE_ENV=development

# Enable debug mode
DEBUG=false

# Log level (error, warn, info, debug)
LOG_LEVEL=info

# ============================================
# NOTES
# ============================================

# 1. Never commit .env.local to version control
# 2. Always use strong, randomly generated secrets in production
# 3. Rotate secrets regularly
# 4. Use different values for development and production
# 5. Store production secrets in secure vault (e.g., AWS Secrets Manager)
